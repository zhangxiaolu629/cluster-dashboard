# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Better Auth 本地 SQLite（见 README `AUTH_DATABASE_PATH`）
/.data/

# Better Auth 账号列表 JSON（见 README `AUTH_USERS_JSON_FILE`）
auth-users.local.json

# local AI config links (generated by scripts/setup-shared-links.mjs)
.cursor/rules
.cursor/rules.bak-*
.trae/rules
